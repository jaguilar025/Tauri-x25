{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tauri x25",
  "version": "1.3.0",
  "identifier": "dev.tauri-x25.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Tauri x25",
        "width": 1000,
        "height": 680,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "category": "Utility",
    "shortDescription": "Lightweight Linux network monitor",
    "longDescription": "Real-time per-process and historical per-interface network usage built on nethogs and vnstat.",
    "linux": {
      "deb": {
        "depends": ["nethogs", "vnstat", "policykit-1", "libayatana-appindicator3-1"],
        "files": {
          "/usr/share/tauri-x25/scripts/install-polkit-rule.sh": "../scripts/install-polkit-rule.sh"
        }
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}
